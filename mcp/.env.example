# NotebookLM MCP Server - Environment Configuration
# Copy this file to .env to set up environment variables.
# The .env file is gitignored and should NEVER be committed.

# Authentication:
# You can authenticate by running `notebooklm login` on your local machine.
# This creates a state file at ~/.notebooklm/storage_state.json.
# By default, the server will automatically look for this file.

# If your state file is located somewhere else, you can override the path here:
# NOTEBOOKLM_STORAGE_PATH=/path/to/your/storage_state.json

# Alternatively, if you cannot mount files (e.g., in some cloud deployments),
# you can paste the JSON content directly as a single-line string:
# NOTEBOOKLM_AUTH_JSON='{"cookies":[...]}'
