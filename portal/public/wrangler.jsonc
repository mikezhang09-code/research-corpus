{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "research-portal-public",
  "main": ".open-next/worker.js",
  "compatibility_date": "2025-05-05",
  "compatibility_flags": ["nodejs_compat"],
  "assets": {
    "binding": "ASSETS",
    "directory": ".open-next/assets"
  },
  "observability": {
    "enabled": true
  },
  // SUPABASE_URL, R2_PUBLIC_URL, and the AI provider base/model names are
  // plain vars (not secret). The service-role key and the model API keys
  // are secrets — set them with:
  //   wrangler secret put SUPABASE_SERVICE_ROLE_KEY
  //   wrangler secret put ANTHROPIC_API_KEY
  //   wrangler secret put GEMINI_API_KEY   (synced by the deploy workflow)
  // AI generate tries MiMo first, then falls back to Gemini (same policy as
  // portal/backend/ai.py).
  "vars": {
    "SUPABASE_URL": "https://llusronucprogsrgzxrw.supabase.co",
    "R2_PUBLIC_URL": "https://pub-7476dba8b5e64618bdb1c80b8df63baa.r2.dev",
    "ANTHROPIC_BASE_URL": "https://api.xiaomimimo.com/anthropic",
    "ANTHROPIC_MODEL": "mimo-v2.5",
    "GEMINI_MODEL": "gemini-2.5-flash"
  },
  // R2 bucket binding — used to write/delete folio file objects. File reads
  // still go through the public URL (see streamR2 in src/lib/supabase.ts).
  "r2_buckets": [
    { "binding": "R2_BUCKET", "bucket_name": "research-portal" }
  ]
}
