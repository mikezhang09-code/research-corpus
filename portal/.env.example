# Research Portal — Environment Variables
# Copy this file to .env and fill in every value
# Setup instructions: docs/portal-infrastructure-setup.md

# =============================================================================
# Supabase
# Settings → API in your Supabase project dashboard
# =============================================================================

SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Direct PostgreSQL connection string — used to run schema migrations
# Supabase dashboard: Settings → Database → Connection string → URI
# Note: URL-encode special chars in password: @ → %40, # → %23, % → %25
DATABASE_URL=postgresql://postgres:your-password@db.your-project-ref.supabase.co:5432/postgres

# =============================================================================
# Cloudflare R2
# R2 overview → Manage R2 API Tokens in Cloudflare dashboard
# =============================================================================

R2_ACCOUNT_ID=your-32-char-account-id
R2_ACCESS_KEY_ID=your-r2-access-key-id
R2_SECRET_ACCESS_KEY=your-r2-secret-access-key
R2_BUCKET_NAME=research-portal
R2_ENDPOINT_URL=https://your-account-id.r2.cloudflarestorage.com
R2_PUBLIC_URL=https://pub-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx.r2.dev

# =============================================================================
# NotebookLM (existing CLI config — usually already set)
# =============================================================================

# NOTEBOOKLM_HOME=~/.notebooklm

# =============================================================================
# Portal server
# =============================================================================

PORTAL_HOST=0.0.0.0
PORTAL_PORT=8000
PORTAL_ENV=development

# =============================================================================
# Chat model (Library Notebook chat — Anthropic-compatible API)
# The default base URL points at Xiaomi's MiMo proxy. List available models:
#   curl -H "x-api-key: $ANTHROPIC_API_KEY" \
#        https://token-plan-sgp.xiaomimimo.com/v1/models
# =============================================================================

ANTHROPIC_API_KEY=your-anthropic-api-key-here
ANTHROPIC_BASE_URL=https://token-plan-sgp.xiaomimimo.com/anthropic
# Pick a model from /v1/models. MiMo options:
#   mimo-v2.5-pro    — latest, recommended
#   mimo-v2.5        — latest, smaller
#   mimo-v2-pro      — previous gen
#   mimo-v2-omni     — multimodal-style
ANTHROPIC_MODEL=mimo-v2.5-pro
ANTHROPIC_MAX_TOKENS=2048

# =============================================================================
# Google Gemini (automatic fallback when MiMo is unavailable)
# Get a free key at https://aistudio.google.com/apikey
# =============================================================================

GEMINI_API_KEY=your-gemini-api-key-here
